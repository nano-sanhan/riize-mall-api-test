      "name": "登录接口",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 登录接口：提取 JSESSIONID 并存入环境变量\r",
              "const jsessionId = pm.cookies.get(\"JSESSIONID\");\r",
              "pm.environment.set(\"JSESSIONID\", jsessionId);\r",
              "\r",
              "pm.test(\"登录接口可达\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"text/html\");\r",
              "    pm.expect(pm.response.text()).to.match(/(用户|登录|首页)/);\r",
              "});\r",
              "\r",
              "pm.test(\"JSESSIONID 已保存\", function () {\r",
              "    pm.expect(pm.environment.get(\"JSESSIONID\")).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
