          "listen": "test",
          "script": {
            "exec": [
              "// 1. 自动提取登录后的 JSESSIONID 并存入环境变量\r",
              "pm.environment.set(\"JSESSIONID\", pm.cookies.get(\"JSESSIONID\"));\r",
              "\r",
              "// 2. 断言登录成功（兼容 302 重定向或 200 管理页）\r",
              "pm.test(\"登录成功，跳转到商品管理中心\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([302, 200]);\r",
              "    if (pm.response.code === 302) {\r",
              "        // 原始重定向：验证 Location 跳转到管理中心\r",
              "        pm.expect(pm.response.headers.get(\"Location\")).to.include(\"goods?action=manage\");\r",
              "    } else {\r",
              "        // 重定向后页面：验证包含「商品管理中心」\r",
              "        pm.expect(pm.response.text()).to.include(\"后台管理\");\r",
              "    }\r",
              "});\r",
              "\r",
              "// 3. 断言 JSESSIONID 已成功提取（可选）\r",
              "pm.test(\"JSESSIONID 已获取\", function () {\r",
              "    pm.expect(pm.environment.get(\"JSESSIONID\")).to.not.be.empty;\r",
              "});"
            ],
