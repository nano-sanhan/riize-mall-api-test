  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// 集合级 Pre-request Script：自动为所有接口携带 JSESSIONID\r",
          "const jsessionId = pm.environment.get(\"JSESSIONID\");\r",
          "\r",
          "if (jsessionId) {\r",
          "    // 先移除已有的 Cookie 头，避免重复\r",
          "    pm.request.headers.remove(\"Cookie\");\r",
          "    // 添加新的 Cookie 头，携带 JSESSIONID\r",
          "    pm.request.headers.add({\r",
          "        key: \"Cookie\",\r",
          "        value: `JSESSIONID=${jsessionId}`\r",
          "    });\r",
          "    console.log(\"✅ 集合级：已自动携带 JSESSIONID:\", jsessionId);\r",
          "} else {\r",
          "    console.warn(\"⚠️ 集合级：未获取到 JSESSIONID，请先执行登录接口\");\r",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// 集合级 Post-response Script：通用兼容登录页断言\r",
          "pm.test(\"接口可达且返回有效页面\", function () {\r",
          "    // 1. 验证状态码为 200（或 302，根据需要调整）\r",
          "    pm.response.to.have.status(200);\r",
          "    \r",
          "    // 2. 验证返回的是 HTML 页面\r",
          "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"text/html\");\r",
          "    \r",
          "    // 3. 通用匹配：只要页面包含「登录」或业务关键词，就算通过\r",
          "    // 这里覆盖了你项目里的所有业务场景\r",
          "    pm.expect(pm.response.text()).to.match(\r",
          "        /(登录|商品|购物车|我的订单|订单管理|我的个人中心|RIIZE store后台管理系统)/\r",
          "    );\r",
          "});"
        ]
      }
    }
  ]
}