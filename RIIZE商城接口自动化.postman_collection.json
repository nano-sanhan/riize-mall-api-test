              "        pm.expect(location.includes(\"goods?action=manage\")).to.be.true;\r",
              "    } else {\r",
              "        // 场景2：自动重定向后拿到 200，验证是商品管理页\r",
              "        pm.expect(pm.response.text()).to.include(\"商品管理\");\r",
              "    }\r",
              "});\r",
