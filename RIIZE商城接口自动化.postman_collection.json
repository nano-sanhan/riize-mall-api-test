          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"加入购物车成功\", function () {\r",
              "    // 1. 验证状态码（成功后通常是 200 或 302 重定向到购物车列表）\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);\r",
              "    // 2. 验证结果：如果是 302，检查重定向到购物车列表；如果是 200，检查提示文字\r",
              "    if (pm.response.code === 302) {\r",
              "        pm.expect(pm.response.headers.get(\"Location\")).to.include(\"cart?action=list\");\r",
              "    } else {\r",
              "        pm.expect(pm.response.text()).to.include(\"提交选中商品订单\");\r",
              "    }\r",
              "});"
